<?xml version="1.0"?>
<launch>
  <!-- Record DWA Metrics Launch File -->
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="map_file" default="$(find turtlebot3_navigation)/maps/bookstore_map.yaml"/>
  <arg name="metrics_file" default="$(find turtlebot3_metrics)/data/metrics.csv"/>
  
  <!-- Start Gazebo -->
  <include file="$(find turtlebot3_gazebo)/launch/bookstore.launch">
    <arg name="model" value="$(arg model)"/>
  </include>
  
  <!-- Map server -->
  <node pkg="map_server" name="map_server" type="map_server" args="$(arg map_file)"/>
  
  <!-- AMCL -->
  <include file="$(find turtlebot3_navigation)/launch/amcl.launch"/>
  
  <!-- Move base -->
  <include file="$(find turtlebot3_navigation)/launch/move_base.launch">
    <arg name="model" value="$(arg model)"/>
  </include>
  
  <!-- Metrics Recorder -->
  <node pkg="turtlebot3_metrics" type="record_metrics.py" name="metrics_recorder" output="screen">
    <param name="output_file" value="$(arg metrics_file)"/>
  </node>
  
  <!-- RViz -->
  <node pkg="rviz" type="rviz" name="rviz"
        args="-d $(find turtlebot3_navigation)/rviz/turtlebot3_navigation.rviz"/>
</launch>